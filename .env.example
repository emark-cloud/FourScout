# BSC
BSC_RPC_URL=https://bsc-dataseed1.binance.org

# Four.meme CLI - agent hot wallet (NEVER use your main wallet)
PRIVATE_KEY=

# LLM
GEMINI_API_KEY=

# Database
DATABASE_PATH=./data/fourscout.db

# Scanner
SCAN_INTERVAL_SECONDS=30

# Four.meme API
FOURMEME_API_BASE=https://four.meme/meme-api/v1

# LLM cost controls
AI_EXIT_INTERVAL_CYCLES=10

# Deploy: comma-separated CORS origins. Leave default for local dev.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Deploy: shared-secret for /api/* and /ws. Empty = auth disabled (local dev only).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=
